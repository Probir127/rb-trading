# ============================================
# Environment Variables for RB Trading E-commerce
# Copy this file to .env and fill in your values
# ============================================

# Django Settings
DEBUG=True
SECRET_KEY=your-django-secret-key-here

# SSLCommerz Payment Gateway
# Get credentials from https://developer.sslcommerz.com/
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASS=your_store_password
SSLCOMMERZ_IS_SANDBOX=True

# Email / SMTP Configuration (Gmail)
# For Gmail: Enable 2FA, then create App Password at
# https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Frontend URL (for payment gateway callbacks)
FRONTEND_URL=http://localhost:5173

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
